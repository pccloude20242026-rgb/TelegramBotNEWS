# @BotFather'dan olingan token
BOT_TOKEN=123456:ABC-DEF...

# Bot admin bo'lgan kanal username (@kanal_nomi) yoki ID (-100...)
CHANNEL_ID=@mening_kanalim

# Oltin, Kumush, BTC uchun API key KERAK EMAS (gold-api.com va Binance bepul)

# Neft (WTI) narxi uchun: https://www.oilpriceapi.com/ dan bepul ro'yxatdan
# o'ting (kartasiz). Agar bo'sh qoldirsangiz, neft narxi ko'rsatilmaydi.
OILPRICEAPI_KEY=your_key_here

# USD/UZS uchun API key KERAK EMAS (cbu.uz rasmiy va bepul)

# Ixtiyoriy sozlamalar (standart qiymatlar bilan qoldirsangiz ham bo'ladi)
FAST_PRICE_UPDATE_INTERVAL=120
SLOW_PRICE_UPDATE_INTERVAL=14400
NEWS_CHECK_INTERVAL=300
MIN_NEWS_IMPACT=Medium
